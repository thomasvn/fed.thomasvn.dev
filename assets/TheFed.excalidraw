      "link": null,
      "locked": false,
      "text": "ADDITIONAL REFERENCE INFO",
      "fontSize": 26.606185736161677,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "ADDITIONAL REFERENCE INFO",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "mlTfWSGEycJfrsBLwXLng",
      "type": "text",
      "x": -303.5487996570961,
      "y": 1800.2814537682532,
      "width": 651.9136407492846,
      "height": 230.8579132410986,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "4v2F6mInWCe75fA--RFAD",
        "OCCKUGd9FCNOd89rYoI78"
      ],
      "frameId": null,
      "index": "b1X",
      "roundness": null,
      "seed": 771574515,
      "version": 1028,
      "versionNonce": 56535501,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776141518219,
      "link": null,
      "locked": false,
      "text": "1. Short term borrowing costs\n\nThese rates follow the FFR.\n\nIt affects retail loans like credit cards, auto loans,\nHELOCs, and business loans. Retail loans often use the\nPrime Rate (FFR + 3%) and add an additional spread on\ntop of that.",
      "fontSize": 23.08579132410986,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Short term borrowing costs\n\nThese rates follow the FFR.\n\nIt affects retail loans like credit cards, auto loans, HELOCs, and business loans. Retail loans often use the Prime Rate (FFR + 3%) and add an additional spread on top of that.",
      "autoResize": false,
      "lineHeight": 1.25
    },
