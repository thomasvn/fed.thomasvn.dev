      "lineHeight": 1.25
    },
    {
      "id": "f6Qq93iMn0GiXO8y6ohPB",
      "type": "text",
      "x": -319.81097599711325,
      "y": 2144.2473332270583,
      "width": 1324.6251612723343,
      "height": 140.0277476626484,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "4v2F6mInWCe75fA--RFAD"
      ],
      "frameId": null,
      "index": "b1A",
      "roundness": null,
      "seed": 504434245,
      "version": 625,
      "versionNonce": 780635107,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776141483804,
      "link": null,
      "locked": false,
      "text": "UNEMPLOYMENT. High rates → borrowing gets expensive → businesses invest less and hire less → unemployment rises\n\nINFLATION. High rates → less money circulating, asset prices fall, consumers feel poorer and spend less → inflation falls\n\nReverse for low rates",
      "fontSize": 22.404439626023752,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "UNEMPLOYMENT. High rates → borrowing gets expensive → businesses invest less and hire less → unemployment rises\n\nINFLATION. High rates → less money circulating, asset prices fall, consumers feel poorer and spend less → inflation falls\n\nReverse for low rates",
      "autoResize": true,
      "lineHeight": 1.25
    },
